# L.O.R.E Server Configuration Example

# API authentication key for Freya gateway
API_KEY=koala

# Directories and database paths
LORE_BASE_DIR=./data
LORE_DB_PATH=./data/saraswati_db
LORE_PSYCHE_PATH=./data/psyche_db

# Local LLM Flag (if False, local models/workflows are bypassed and cloud LLM is used)
LOCAL_LLM=False

# Cloud AI Settings (defaults to Gemini API OpenAI compatibility endpoint)
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_API_KEY=your_gemini_or_openai_api_key
OPENAI_MODEL=gemini-1.5-flash

# JWT Configuration for session authentication
JWT_SECRET=super-secret-jwt-key-replace-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=168

# Email settings for passwordless magic links (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@lore.local
